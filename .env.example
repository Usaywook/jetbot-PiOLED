# Copy this file to `.env` (which is gitignored) and fill in the values.
# `run.sh` will pass it into the container via `--env-file`.

# Slack incoming webhook URL. If empty/unset, temperature alerts are disabled
# silently (stats display still works).
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Junction temperature threshold in degrees Celsius (float).
# Orin Nano begins thermal throttling around 80°C.
TEMP_ALERT_C=80

# Seconds the temperature must stay >= TEMP_ALERT_C before sending the alert.
# Filters out short spikes (e.g. compile bursts) so Slack stays quiet.
TEMP_ALERT_SUSTAIN_S=30

# Seconds the temperature must stay < TEMP_ALERT_C before sending the recovery
# ("[OK]") message. Prevents flapping when temp hovers near the threshold.
TEMP_CLEAR_SUSTAIN_S=60

# Re-alert interval while temperature stays above the threshold (seconds).
# 0 or empty = single alert per crossing (no repeats). Any positive value
# triggers a `[ALERT-REPEAT]` message every N seconds until temp clears.
TEMP_ALERT_REPEAT_S=600
