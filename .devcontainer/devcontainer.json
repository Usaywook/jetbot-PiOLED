{
    "name": "PiOLED JP6",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    // --privileged + /dev /sys 마운트 필수: I2C 및 GPIO 접근을 위해
    "runArgs": [
        "--runtime=nvidia",
        "--network=host",
        "--privileged"
    ],
    "mounts": [
        "source=/dev,target=/dev,type=bind,consistency=cached",
        "source=/sys,target=/sys,type=bind,consistency=cached"
    ],
    "remoteUser": "root"
}
